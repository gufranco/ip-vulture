{
  "name": "ip-vulture",
  "version": "1.0.0",
  "description": "Captures incoming request IPs and resolves geolocation via ip-api.com",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --env-file=.env --import tsx src/server.ts",
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "local": "./scripts/local.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
